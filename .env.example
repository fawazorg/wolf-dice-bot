# ============================================
# Bot Accounts Configuration
# ============================================
# Multiple bot accounts separated by pipe (|)
# Format: email1:password1|email2:password2
ACCOUNTS=email1@examble.com:password|email2@examble.com:password

# ============================================
# MongoDB Configuration
# ============================================
# Root user credentials for MongoDB authentication
ROOT_USERNAME=
ROOT_PASSWORD=
ROOT_DATABASE=

# Application database credentials
MONGO_USER=
MONGO_PWD=
MONGO_DB_NAME=
