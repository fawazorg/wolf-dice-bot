# ============================================
# Bot Accounts Configuration
# ============================================
# Multiple bot accounts separated by pipe (|)
# Format: email1:password1|email2:password2
ACCOUNTS=email1@examble.com:password|email2@examble.com:password

# ============================================
# MongoDB Configuration
# ============================================
# Root user credentials for MongoDB authentication
ROOT_USERNAME=
ROOT_PASSWORD=
ROOT_DATABASE=

# Application database credentials
MONGO_USER=
MONGO_PWD=
MONGO_DB_NAME=

# ============================================
# Admin Configuration
# ============================================
# Comma-separated list of admin user IDs
# These users have elevated permissions to execute admin commands
# Example: 12345678,87654321
ADMIN_IDS=

# Special admin group ID for notifications and logs
# Bot will send administrative notifications to this group
ADMIN_GROUP_ID=

# Comma-separated list of group IDs to ignore in bot operations
# These groups won't be auto-left due to inactivity
# Example: 11111111,22222222
IGNORE_GROUP_IDS=
