# ==============================================================================
# Environment Configuration - Wolf Dice Bot
# ==============================================================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!
# ==============================================================================

# ==============================================================================
# Docker Compose Configuration
# ==============================================================================
# Project name (used for container/network/volume prefixes)
# Change this to avoid conflicts with other projects
COMPOSE_PROJECT_NAME=wolf-dice

# Restart policy: no | always | on-failure | unless-stopped
RESTART_POLICY=unless-stopped

# ==============================================================================
# Network Configuration
# ==============================================================================
# Custom subnet to avoid conflicts with other Docker projects
# Change if 172.28.0.0/16 conflicts with existing networks
NETWORK_SUBNET=172.28.0.0/16
NETWORK_BRIDGE_NAME=br-wolf-dice

# ==============================================================================
# MongoDB Configuration
# ==============================================================================
# MongoDB version (8.0, 7.0, 6.0)
MONGO_VERSION=8.0

# MongoDB host port (change if 27017 is already in use)
# Example: 27018, 27019, etc.
MONGO_HOST_PORT=27017

# Root user credentials (for MongoDB admin)
# SECURITY: Use strong passwords in production!
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=changeme_root_password_here
MONGO_INITDB_DATABASE=admin

# Application database credentials
# These are created by the init script
MONGO_USER=wolf_dice_user
MONGO_PWD=changeme_app_password_here
MONGO_DB_NAME=wolf_dice_db

# MongoDB resource limits
MONGO_CPU_LIMIT=1.0
MONGO_CPU_RESERVE=0.25
MONGO_MEMORY_LIMIT=512M
MONGO_MEMORY_RESERVE=256M

# ==============================================================================
# Redis Configuration
# ==============================================================================
# Redis version (7, 6)
REDIS_VERSION=7-alpine

# Redis host port (change if 6379 is already in use)
# Example: 6380, 6381, etc.
REDIS_HOST_PORT=6379

# Redis password (leave empty for no password in development)
# SECURITY: Always set a password in production!
REDIS_PASSWORD=

# Redis memory configuration
REDIS_MAX_MEMORY=256mb
REDIS_AOF_ENABLED=yes

# Redis resource limits
REDIS_CPU_LIMIT=0.5
REDIS_CPU_RESERVE=0.1
REDIS_MEMORY_LIMIT=256M
REDIS_MEMORY_RESERVE=128M

# ==============================================================================
# Logging Configuration
# ==============================================================================
# Log file rotation settings (prevents disk space exhaustion)
LOG_MAX_SIZE=10m
LOG_MAX_FILES=3

# ==============================================================================
# Bot Application Configuration
# ==============================================================================
# Multiple bot accounts separated by pipe (|)
# Format: email1:password1|email2:password2
ACCOUNTS=email1@example.com:password1|email2@example.com:password2

# Node environment: development | production
NODE_ENV=development

# ==============================================================================
# Optional: Application Container Configuration
# ==============================================================================
# Uncomment these if you containerize the Node.js app

# Application host port (if serving HTTP)
# APP_HOST_PORT=3000

# Application resource limits
# APP_CPU_LIMIT=1.0
# APP_CPU_RESERVE=0.25
# APP_MEMORY_LIMIT=512M
# APP_MEMORY_RESERVE=256M

# ==============================================================================
# Security Recommendations
# ==============================================================================
# 1. Generate strong random passwords:
#    openssl rand -base64 32
#
# 2. Never use default passwords in production
#
# 3. Restrict port exposure:
#    - Don't expose Redis/MongoDB ports if only accessed internally
#    - Use firewall rules to limit access
#
# 4. Regular backups:
#    docker compose exec mongodb mongodump --archive=/data/backup.gz --gzip
#
# 5. Keep images updated:
#    docker compose pull && docker compose up -d
# ==============================================================================
